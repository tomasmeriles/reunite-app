# Do NOT complete this file with real values and commit it to version control.
# Create a copy named .env and fill in the values before running the backend.

# =========================
# DATABASE
# =========================

# DEV (backend in host, Postgres in Docker):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DB

# PROD (backend in Docker, Postgres in Docker):
# DATABASE_URL=postgresql://USER:PASSWORD@db:5432/DB
DATABASE_URL=

# =========================
# APP CONFIG
# =========================

# Node env: development | test | production
NODE_ENV=

# Default port is 3000, but you can change it if needed
PORT=3000
# e.g. http://localhost:5173 for Vite dev server, or https://myapp.com in production
FRONTEND_URL=

# Shared registrable domain for auth cookies. Required in production so Safari
# ITP treats cookies as first-party (frontend and backend must share this domain).
# Must start with a dot, e.g. .tudominio.com
# Leave empty in development.
COOKIE_DOMAIN=

# Log level: fatal | error | warn | info | debug | trace | silent
# Use 'debug' in development to see verbose output
LOG_LEVEL=info

# Google OAuth 2.0 (use different credentials for dev and prod)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Set this to a short time (e.g. 15 minutes) for better security
JWT_ACCESS_EXPIRES_MINUTES=
# Set this to a longer time (e.g. 7 days) for better user experience
JWT_REFRESH_EXPIRES_DAYS=

# Secret used to sign CSRF tokens (HMAC-SHA256). Must be different from JWT_SECRET.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# =========================
# REDIS
# =========================

# DEV (backend in host, Redis in Docker):
# REDIS_URL=redis://localhost:6379

# PROD (backend in Docker, Redis in Docker):
# REDIS_URL=redis://redis:6379
REDIS_URL=

# =========================
# RATE LIMITING
# =========================

# Safety fallback applied to endpoints that are missing an explicit @Throttle() or @SkipThrottle() decorator.
# Fallback window in seconds
THROTTLE_TTL_SECONDS=60
# Fallback max requests per window
THROTTLE_LIMIT=30

# =========================
# S3 / OBJECT STORAGE
# =========================

# AWS region (also used by MinIO, set to any value like us-east-1)
S3_REGION=us-east-1

# For AWS: use IAM credentials
# For MinIO: use the MINIO_ROOT_USER / MINIO_ROOT_PASSWORD values from the root .env
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# The bucket name to use for uploads
S3_BUCKET=

# MinIO / self-hosted S3 only - omit this for AWS
# DEV (backend on host, MinIO in Docker):
# S3_ENDPOINT=http://localhost:9000
# PROD (backend in Docker, MinIO in Docker):
# S3_ENDPOINT=http://minio:9000
S3_ENDPOINT=

# Must be true for MinIO (path-style URLs). Set false or omit for AWS.
S3_FORCE_PATH_STYLE=false

# Optional: base URL for getPublicUrl() - use when a CDN sits in front of storage.
# Example (Cloudflare + MinIO):  S3_PUBLIC_BASE_URL=https://assets.myapp.com
# Example (CloudFront + S3):     S3_PUBLIC_BASE_URL=https://d1234abcd.cloudfront.net
# If omitted, falls back to S3_ENDPOINT/bucket/key (MinIO) or AWS virtual-hosted style.
S3_PUBLIC_BASE_URL=

# =========================
# SUPER ADMIN
# =========================

# If set, a SUPER_ADMIN user will be created via seeding with this email and name.
# Run `pnpm run db:seed` to execute all seeds (entry point: prisma/seed.js).
# Individual seeds can also be run standalone, e.g.:
#   node prisma/seeds/super-admin.seed.js
# In production, seeds are blocked by default.
# Pass SEED_FORCE=true to override this safety mechanism and run seeds in production intentionally.
# Use the same email as your Google account to gain access via OAuth.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_NAME="Super Admin"
