generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

/// Represents a platform user. Auth supports both OAuth and local email/password.
/// globalRole controls platform-level access; event-level access is managed via EventStaff.
model User {
  id              String     @id @default(cuid())
  email           String     @unique
  username        String     @unique // @handle used for invite lookups, e.g. "juanperez"
  name            String?
  avatar          String?
  passwordHash    String? // null for OAuth-only accounts
  emailVerifiedAt DateTime? // null = unverified
  globalRole      GlobalRole @default(MEMBER)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  oauthAccounts    OAuthAccount[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  memberships      EventStaff[] // which events this user is an organizer of
  whitelistEntries EventWhitelistEntry[]
  attendees        EventAttendee[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// OAuth - external identity providers linked to a User
// ---------------------------------------------------------------------------

/// Supported OAuth providers. Extend here when adding new ones.
enum OAuthProvider {
  GOOGLE
}

/// Stores the OAuth tokens and provider-specific account ID for a linked provider.
/// A user may have multiple accounts (one per provider).
model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

// ---------------------------------------------------------------------------
// RefreshToken - rotating refresh token store (hashed, never stored raw)
// ---------------------------------------------------------------------------

/// Tracks issued refresh tokens using a hash (SHA-256) of the raw token.
/// Supports token rotation: when a token is rotated, replacedBy records its successor.
/// Revoked tokens remain in the table for audit purposes until cleanup.
model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique // SHA-256 hash of the raw token
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime? // null = still valid
  replacedBy String? // tokenHash of the successor token (set on rotation)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// AuditLog - immutable event log for security-sensitive operations
// ---------------------------------------------------------------------------

/// Actions that can be recorded in the audit log.
enum AuditAction {
  LOGIN
  LOGOUT
  TOKEN_REVOKED
  REGISTER
  UPDATE
  DELETE
  EVENT_CREATED
  EVENT_UPDATED
  ATTENDEE_REGISTERED
  ATTENDEE_CANCELLED
}

/// Resources that audit events can target.
enum AuditResource {
  USER
  SESSION
  OAUTH_ACCOUNT
  EVENT
  INVITE_LINK
  ATTENDEE
}

/// Append-only log of security-relevant events. userId is nullable to capture
/// failed/anonymous actions (e.g. failed login before the user is identified).
model AuditLog {
  id         String        @id @default(cuid())
  userId     String?
  action     AuditAction
  resource   AuditResource
  resourceId String?
  requestId  String?
  success    Boolean       @default(true)
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime      @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Roles - two-tier RBAC model
//
// Tier 1 – GlobalRole: platform-wide, stored on User.
//   SUPER_ADMIN     -> unrestricted access to everything (CASL: manage all)
//   MODERATOR       -> can create, update, and delete any Event and its members,
//                      but has no special access to other resources
//   MEMBER          -> access determined entirely by EventStaff roles
//
// Tier 2 – EventRole: scoped to a single Event, stored on EventStaff.
//   OWNER     -> event creator / full control
//   ORGANIZER -> co-organizer / manage attendees, modules, prizes (cannot delete event)
// ---------------------------------------------------------------------------

enum GlobalRole {
  SUPER_ADMIN
  MODERATOR
  MEMBER
}

// ---------------------------------------------------------------------------
// EventStaff - RBAC join table between User and Event
// ---------------------------------------------------------------------------

enum EventRole {
  OWNER // full control: manage event settings, members, and sub-resources
  ORGANIZER // manage attendees, modules, prizes; cannot delete the event
}

/// Join table between User and Event. One row = one organizer membership.
/// Attendees are tracked separately in EventAttendee.
model EventStaff {
  id       String    @id @default(cuid())
  eventId  String
  userId   String
  role     EventRole @default(ORGANIZER)
  joinedAt DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_staff")
}

// ---------------------------------------------------------------------------
// Events
// ---------------------------------------------------------------------------

/// Controls who can register for an event.
enum EventType {
  PUBLIC // anyone with the link can register (no account required)
  INVITE_LINK // only people with a valid InviteLink token can register
  INVITE_ACCOUNT // only whitelisted accounts (@username) can register
}

/// Lifecycle state of an event.
enum EventStatus {
  DRAFT // created but not published
  PUBLISHED // visible and accepting registrations
  ACTIVE // event is currently happening
  RESCHEDULED // date was changed after publishing (auto-set)
  ENDED // event has concluded
  CANCELLED // cancelled by organizer
}

/// Type of a dynamic event rule value.
enum EventRuleType {
  STRING
  BOOL
  NUMBER
}

/// Status of an attendee's registration.
enum AttendeeStatus {
  CONFIRMED
  CANCELLED
  WAITLISTED
}

/// The main event record. Organizers are tracked in EventStaff.
model Event {
  id              String      @id @default(cuid())
  title           String
  description     String?
  coverImage      String? // S3 key or public URL
  location        String?
  latitude        Float? // WGS-84 decimal degrees
  longitude       Float? // WGS-84 decimal degrees
  timezone        String // IANA timezone, e.g. "America/New_York"
  startAt         DateTime
  endAt           DateTime // always set by service as startAt + duration
  duration        Int       @default(60) // minutes
  startedAt       DateTime? // actual activation time (set when status → ACTIVE)
  endedAt         DateTime? // actual end time (set when status → ENDED)
  maxAttendees    Int? // null = unlimited
  eventType       EventType   @default(PUBLIC)
  status          EventStatus @default(DRAFT)
  preEventText    String? // shown before the event
  postEventText   String? // shown after the event
  previousEventId String? // chain: this event comes after previousEvent
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  staff         EventStaff[]
  previousEvent Event?                @relation("EventChain", fields: [previousEventId], references: [id])
  nextEvents    Event[]               @relation("EventChain")
  config        EventConfig?
  rules         EventRule[]
  inviteLinks   InviteLink[]
  whitelist     EventWhitelistEntry[]
  attendees     EventAttendee[]
  chatMessages  ChatMessage[]
  mediaItems    MediaItem[]
  prizes        Prize[]

  @@index([status])
  @@index([startAt])
  @@map("events")
}

/// Per-event feature toggles and visibility settings (1-to-1 with Event).
model EventConfig {
  id              String  @id @default(cuid())
  eventId         String  @unique
  attendeesPublic Boolean @default(true) // show attendee list publicly
  chatEnabled     Boolean @default(true)
  mediaEnabled    Boolean @default(true)
  prizesEnabled   Boolean @default(true)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_configs")
}

/// Dynamic rule attached to an event (e.g. dress code, age restriction).
model EventRule {
  id       String        @id @default(cuid())
  eventId  String
  name     String
  ruleType EventRuleType
  value    String // stored as string; parsed on read according to ruleType

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_rules")
}

/// A shareable invite link for INVITE_LINK events.
/// One link can be used up to maxUses times (null = unlimited).
model InviteLink {
  id        String    @id @default(cuid())
  eventId   String
  token     String    @unique @default(uuid())
  maxUses   Int? // null = unlimited
  useCount  Int       @default(0)
  expiresAt DateTime?
  label     String?
  createdAt DateTime  @default(now())

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendees EventAttendee[]

  @@index([eventId])
  @@map("invite_links")
}

/// Whitelist entry for INVITE_ACCOUNT events.
/// Created by the organizer by searching @username; user accepts by registering.
model EventWhitelistEntry {
  id        String         @id @default(cuid())
  eventId   String
  userId    String
  status    AttendeeStatus @default(WAITLISTED)
  createdAt DateTime       @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_whitelist_entries")
}

/// Represents a single person attending an event.
/// Either a registered User (userId set) or an anonymous guest (guestToken set).
model EventAttendee {
  id           String         @id @default(cuid())
  eventId      String
  userId       String? // null for guests
  guestToken   String?        @unique // UUID stored in client localStorage
  guestName    String? // display name for guests
  addedById    String? // attendee who added this person (for group add)
  inviteLinkId String? // which invite link was used
  status               AttendeeStatus @default(CONFIRMED)
  cancellationReason   String?
  registeredAt         DateTime       @default(now())

  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  inviteLink      InviteLink?    @relation(fields: [inviteLinkId], references: [id], onDelete: SetNull)
  sponsoredBy     EventAttendee? @relation("SponsoredGuests", fields: [addedById], references: [id], onDelete: SetNull)
  sponsoredGuests EventAttendee[] @relation("SponsoredGuests")
  chatMessages    ChatMessage[]
  mediaItems      MediaItem[]
  prizes          Prize[]        @relation("PrizeWinner")

  @@unique([eventId, userId]) // a user can only attend once per event
  @@index([eventId])
  @@index([guestToken])
  @@map("event_attendees")
}

// ---------------------------------------------------------------------------
// Modules — Chat, Media, Prizes
// ---------------------------------------------------------------------------

/// A single chat message in an event's chat room.
model ChatMessage {
  id         String   @id @default(cuid())
  eventId    String
  attendeeId String
  content    String
  createdAt  DateTime @default(now())

  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee EventAttendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@map("chat_messages")
}

/// An image or media item uploaded to an event's gallery.
model MediaItem {
  id           String   @id @default(cuid())
  eventId      String
  attendeeId   String
  s3Key        String // full S3 object key
  thumbnailKey String? // S3 key for the generated thumbnail
  caption      String?
  createdAt    DateTime @default(now())

  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee EventAttendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@map("media_items")
}

/// A prize that can be awarded to an attendee at an event.
model Prize {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  imageUrl    String?
  winnerId    String? // EventAttendee.id of the winner
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event  Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  winner EventAttendee? @relation("PrizeWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("prizes")
}
