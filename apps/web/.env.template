# Do NOT complete this file with real values and commit it to version control.
# Create a copy named .env and fill in the values before running the frontend.

# =========================
# FRONTEND CONFIG
# =========================
# Vite dev server URL (e.g. http://localhost:5173) or production URL (e.g. https://myapp.com)
VITE_API_URL=

# The name of the app, used in the title and other places
VITE_APP_NAME=

# Boolean flag to indicate if the app is running in development mode
DEV=

# Boolean flag to indicate if the app is running in production mode
PROD=